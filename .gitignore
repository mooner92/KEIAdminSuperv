# ───────────────────────────────────────────────────────────
# KEI 행정 가이드 / 행정 비서 — .gitignore
# 원칙: 공개 레포 = 코드·설계문서(포트폴리오). 데이터(규정 볼트·HWP)는 비공개.
#       내부 전용 콘텐츠 + 생성물·캐시·비밀·대용량 바이너리를 제외한다.
#       볼트는 git이 아니라 Syncthing(내부 전용)으로 동기화한다. (SECURITY.md 참조)
# 주의: .gitignore 는 줄 끝 인라인 주석을 지원하지 않는다(주석은 항상 줄 단독으로).
# ───────────────────────────────────────────────────────────

# ── 내부 전용 콘텐츠 — 공개 레포에 절대 포함 금지 (KEI 내부 규정 데이터) ──
# 볼트(변환된 규정 원문)·원본 HWP. 히스토리에서도 제거(filter-repo). Syncthing으로만 동기화.
KEI-행정가이드/
rule_files/
*.hwp
*.hwpx

# ── Python (tools/) ──
tools/.venv/
.venv/
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# ── 벡터DB / 임베딩 캐시 (재생성 가능) ──
tools/chroma/
chroma/
*.sqlite3
.cache/

# ── 비서 앱 DB / 비밀키 (사용자·채팅 데이터 + 규정 스니펫 포함 → 커밋 금지) ──
tools/app.db
tools/app.db-wal
tools/app.db-shm
tools/.app_secret

# ── 원본 규정/가이드 소스 (내부 전용 — 절대 커밋 금지) ──
rule_files/
research_rule_files/
*.hwp
*.hwpx
*.pptx
*.ppt
*.doc
*.docx
# ERP 기능 분석 원본(내부 시스템 구조 — 커밋 금지. 구조화 결과는 볼트(역시 gitignore)로)
KEI_ERP_entire_features.md
KEI_ERP*.md
KEI_admin_terms.md
KEI_*_terms.md
# 로컬에 내려받은 임베딩/모델 가중치
models/

# ── HWP 변환 중간 산출물 ──
# LibreOffice → PDF 중간물
tools/pdf/
*.pdf
# 변환 전 원본 HWP 보관 폴더 — 내부 문서, 비공개
원본HWP/

# ── Syncthing 런타임(디바이스 키·상태 — 비밀) ──
deploy/syncthing-config/

# ── Quartz 정적 사이트 (그래프 화면) ──
public/
node_modules/
.quartz-cache/

# ── Next.js 웹앱 (web/) — 빌드 산출물·의존성 ──
web/.next/
web/out/
web/next-env.d.ts
.next/
out/

# ── 비밀/환경 ──
.env
*.env
*.local
secrets/
*.key
*.pem

# ── Obsidian 작업공간(공유 불필요) ──
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/cache
.trash/

# ── OS / 에디터 ──
.DS_Store
Thumbs.db
*.swp
.idea/
.vscode/

# Playwright 검증 스크린샷(산출물 — 스크립트만 커밋)
web/verify*.png
verify*.png
